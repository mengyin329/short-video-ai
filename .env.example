# 短视频AI编剧助手 - 环境变量配置文件
# 复制此文件为 .env 并填写你的配置

# ============================================
# 核心配置 - 必填
# ============================================

# 豆包大模型配置 (火山引擎方舟)
# 获取地址：https://console.volcengine.com/ark
ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/v3
ARK_MODEL=doubao-pro-32k

# 或使用其他 OpenAI 兼容的模型 (二选一)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ============================================
# 图像生成配置 - 可选
# ============================================

# 图像生成API配置 (当前使用 coze-coding-dev-sdk)
# 如需切换为其他服务，请修改 src/tools/storyboard_generator.py
IMAGE_GENERATION_API_KEY=your_image_api_key_here
IMAGE_GENERATION_BASE_URL=your_image_api_url_here

# ============================================
# 服务配置
# ============================================

# 服务端口
SERVER_PORT=5000

# 服务主机 (0.0.0.0 表示监听所有网卡)
SERVER_HOST=0.0.0.0

# ============================================
# 日志配置
# ============================================

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/app.log

# ============================================
# 数据存储配置 - 可选
# ============================================

# 数据库配置 (如果需要持久化对话历史)
# DATABASE_URL=postgresql://user:password@localhost:5432/short_video_ai

# 对象存储配置 (如果需要存储生成的图片)
# OSS_ACCESS_KEY_ID=your_oss_access_key
# OSS_ACCESS_KEY_SECRET=your_oss_secret
# OSS_BUCKET_NAME=your_bucket_name
# OSS_ENDPOINT=your_oss_endpoint

# ============================================
# 高级配置 - 一般不需要修改
# ============================================

# 超时时间 (秒)
TIMEOUT_SECONDS=900

# 最大对话轮数 (滑动窗口大小)
MAX_MESSAGES=20

# 是否启用思考模式
THINKING_ENABLED=false

# 温度参数 (0.0-1.0, 越高越随机)
TEMPERATURE=0.85

# Top P 采样参数 (0.0-1.0)
TOP_P=0.95

# 最大输出Token数
MAX_TOKENS=4096

# 最大完成Token数
MAX_COMPLETION_TOKENS=32768
